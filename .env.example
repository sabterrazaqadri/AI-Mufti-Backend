# ===== AI Mufti backend environment =====
# Copy to .env and fill with your OWN (rotated) values. Never commit .env.

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
EMBED_MODEL=models/gemini-embedding-001
# Max tokens generated per reply. Urdu/Arabic script is token-heavy, so keep this
# high enough that long rulings are not truncated mid-sentence.
MAX_OUTPUT_TOKENS=8192

# Postgres (Neon). Keep this secret.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Better Auth — the backend verifies session JWTs against the Next app's JWKS.
# Set this to the public URL of your Next.js app (Better Auth baseURL).
BETTER_AUTH_URL=http://localhost:3000
# Optional explicit override:
# BETTER_AUTH_JWKS_URL=https://your-app.vercel.app/api/auth/jwks

# Comma-separated allowed origins for CORS
CORS_ORIGINS=https://digitalmufti.vercel.app,http://localhost:3000
